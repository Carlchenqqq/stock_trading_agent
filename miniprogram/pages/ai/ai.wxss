/* ============================================
   AI分析页 - 页面样式
   ============================================ */

/* ==================== 股票AI分析视图 ==================== */

/* 股票头部信息卡片 */
.stock-header-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: var(--spacing-md);
  padding: var(--spacing-lg);
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.stock-header-info {
  display: flex;
  flex-direction: column;
}

.stock-header-name {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-text-primary);
}

.stock-header-code {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
  margin-top: var(--spacing-xs);
}

.stock-header-price {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.stock-header-price-value {
  font-size: var(--font-xxl);
  font-weight: 700;
}

.stock-header-change {
  font-size: var(--font-md);
  font-weight: 600;
  margin-top: var(--spacing-xs);
}

/* AI评分卡片 */
.ai-score-card {
  margin: 0 var(--spacing-md) var(--spacing-md);
  padding: var(--spacing-lg);
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
}

.ai-score-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.ai-score-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, var(--color-cyan), var(--color-blue));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-sm);
}

.ai-score-icon-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
}

.ai-score-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

.ai-score-body {
  display: flex;
  align-items: baseline;
  margin-bottom: var(--spacing-md);
}

.ai-score-value {
  font-size: 80rpx;
  font-weight: 700;
  line-height: 1;
}

.ai-score-label {
  font-size: var(--font-md);
  color: var(--color-text-muted);
  margin-left: var(--spacing-xs);
}

.ai-score-bar {
  width: 100%;
}

/* AI分析详情卡片 */
.ai-analysis-card {
  margin: 0 var(--spacing-md) var(--spacing-md);
  border-radius: var(--radius-lg);
  background-color: var(--color-card);
  border: 1rpx solid var(--color-border);
  overflow: hidden;
}

.ai-card-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) var(--spacing-lg) 0;
}

.ai-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, var(--color-cyan), var(--color-blue));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-sm);
}

.action-icon-bg {
  background: linear-gradient(135deg, var(--color-orange), var(--color-yellow));
}

.ai-icon-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
}

.ai-card-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

.ai-card-body {
  padding: var(--spacing-md) var(--spacing-lg) var(--spacing-lg);
}

.ai-analysis-text {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 操作建议卡片 */
.ai-action-card {
  margin: 0 var(--spacing-md) var(--spacing-md);
  border-radius: var(--radius-lg);
  background-color: var(--color-card);
  border: 1rpx solid var(--color-border);
  overflow: hidden;
}

/* ==================== AI仪表盘视图 ==================== */

/* 状态卡片网格 */
.status-card-grid {
  display: flex;
  flex-wrap: wrap;
  padding: var(--spacing-md);
  gap: var(--spacing-md);
}

.status-card {
  flex: 1;
  min-width: calc((100% - var(--spacing-md)) / 3);
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  padding: var(--spacing-md);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-card-label {
  font-size: var(--font-xs);
  color: var(--color-text-muted);
  margin-bottom: var(--spacing-xs);
}

.status-card-value {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
  word-break: break-all;
}

/* 操作按钮网格 */
.ai-action-grid {
  display: flex;
  padding: 0 var(--spacing-md) var(--spacing-md);
  gap: var(--spacing-md);
}

.ai-action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-lg) 0;
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  transition: background-color 0.2s ease;
}

.ai-action-btn:active {
  background-color: var(--color-card-hover);
}

.ai-action-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--spacing-sm);
}

.ai-action-icon-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
}

.market-icon-bg {
  background: linear-gradient(135deg, var(--color-cyan), var(--color-blue));
}

.strategy-icon-bg {
  background: linear-gradient(135deg, #7c4dff, var(--color-blue));
}

.recommend-icon-bg {
  background: linear-gradient(135deg, #00e676, #00bfa5);
}

.ai-action-label {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

/* 分析结果卡片 */
.ai-result-card {
  margin: 0 var(--spacing-md) var(--spacing-md);
  border-radius: var(--radius-lg);
  background-color: var(--color-card);
  border: 1rpx solid var(--color-border);
  overflow: hidden;
}

/* 分析加载中卡片 */
.ai-loading-card {
  margin: 0 var(--spacing-md) var(--spacing-md);
  border-radius: var(--radius-lg);
  background-color: var(--color-card);
  border: 1rpx solid var(--color-border);
  overflow: hidden;
}

.ai-loading-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg) 0;
  gap: 16rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: var(--color-cyan);
  animation: dotPulse 1.4s ease-in-out infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dotPulse {
  0%, 80%, 100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  40% {
    opacity: 1;
    transform: scale(1.2);
  }
}

.ai-loading-text {
  font-size: var(--font-sm);
  color: var(--color-text-muted);
  text-align: center;
  display: block;
  padding-bottom: var(--spacing-md);
}

/* 配置说明区域 */
.config-section {
  margin: 0 var(--spacing-md) var(--spacing-md);
  background-color: var(--color-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  overflow: hidden;
}

.config-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
  border-bottom: 1rpx solid var(--color-border);
}

.config-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, var(--color-text-muted), var(--color-text-secondary));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-sm);
}

.config-icon-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
}

.config-title {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-text-primary);
}

.config-body {
  padding: var(--spacing-md) var(--spacing-lg);
}

.config-item {
  margin-bottom: var(--spacing-md);
}

.config-item:last-child {
  margin-bottom: 0;
}

.config-item-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--color-text-primary);
  display: block;
  margin-bottom: var(--spacing-xs);
}

.config-item-desc {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  display: block;
}
