/* ============================================
   自选股页 - 页面样式
   ============================================ */

/* 下拉刷新提示 */
.refresh-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
}

.refresh-tip-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 骨架屏 */
.skeleton-list {
  padding: 0 24rpx;
}

.skeleton-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}

.skeleton-col-left {
  display: flex;
  flex-direction: column;
}

.skeleton-col-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

/* 股票列表滚动容器 */
.stock-scroll {
  width: 100%;
  height: calc(100vh - env(safe-area-inset-top) - 44px);
}

/* 列表表头 */
.stock-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: var(--color-bg-secondary);
  border-bottom: 1rpx solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.header-name {
  width: 180rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  font-weight: 600;
}

.header-price {
  width: 120rpx;
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-muted);
  font-weight: 600;
}

.header-change {
  width: 110rpx;
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-muted);
  font-weight: 600;
}

.header-volume {
  width: 100rpx;
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-muted);
  font-weight: 600;
}

.header-amount {
  flex: 1;
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-muted);
  font-weight: 600;
}

.header-action {
  width: 72rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-muted);
  font-weight: 600;
}

/* 股票行 */
.stock-row {
  display: flex;
  align-items: center;
  padding: 24rpx 24rpx;
  background-color: var(--color-card);
  border-bottom: 1rpx solid var(--color-border);
  transition: background-color 0.2s ease;
}

.stock-row:active {
  background-color: var(--color-card-hover);
}

/* 股票名称和代码 */
.stock-info {
  width: 180rpx;
  display: flex;
  flex-direction: column;
}

.stock-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  line-height: 1.3;
}

.stock-code {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 4rpx;
}

/* 最新价 */
.stock-price {
  width: 120rpx;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.price-value {
  font-size: 28rpx;
  font-weight: 600;
}

/* 涨跌幅 */
.stock-change {
  width: 110rpx;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.change-value {
  font-size: 26rpx;
  font-weight: 600;
}

/* 成交量 */
.stock-volume {
  width: 100rpx;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.volume-value {
  font-size: 22rpx;
}

/* 成交额 */
.stock-amount {
  flex: 1;
  text-align: right;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 8rpx;
}

.amount-value {
  font-size: 22rpx;
}

/* AI 分析按钮 */
.stock-action {
  width: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-btn-mini {
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, var(--color-cyan), var(--color-blue));
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease;
}

.ai-btn-mini:active {
  opacity: 0.7;
}

.ai-btn-text {
  font-size: 20rpx;
  font-weight: 700;
  color: #ffffff;
}

/* 空状态子标题 */
.empty-sub-text {
  font-size: 24rpx;
  color: var(--color-text-muted);
  margin-top: 12rpx;
}
