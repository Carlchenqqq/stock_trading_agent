/* ============================================
   市场概览页 - 页面样式
   ============================================ */

/* 统计卡片 2x2 网格 */
.stat-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 24rpx 24rpx 0;
  gap: 20rpx;
}

.stat-grid .stat-card {
  width: calc((100% - 20rpx) / 2);
  box-sizing: border-box;
}

/* AI 分析卡片 */
.ai-card {
  margin: 0 24rpx 24rpx;
  border-radius: 24rpx;
  background-color: var(--color-card);
  border: 1rpx solid var(--color-border);
  overflow: hidden;
}

.ai-card-header {
  display: flex;
  align-items: center;
  padding: 28rpx 28rpx 0;
}

.ai-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, var(--color-cyan), var(--color-blue));
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.ai-icon-text {
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
}

.ai-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.ai-card-body {
  padding: 20rpx 28rpx;
}

.ai-analysis-text {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.ai-card-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 28rpx 28rpx;
  border-top: 1rpx solid var(--color-border);
}

.ai-card-footer:active {
  opacity: 0.7;
}

.ai-more-text {
  font-size: 26rpx;
  color: var(--color-cyan);
  margin-right: 8rpx;
}

.ai-arrow {
  font-size: 26rpx;
  color: var(--color-cyan);
}

/* 快捷操作按钮网格 */
.action-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx 48rpx;
  gap: 20rpx;
}

.action-btn {
  width: calc((100% - 60rpx) / 4);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.action-btn:active {
  opacity: 0.7;
}

.action-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-icon-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #ffffff;
}

.strategy-icon {
  background: linear-gradient(135deg, #7c4dff, #448aff);
}

.recommend-icon {
  background: linear-gradient(135deg, #00e676, #00bfa5);
}

.rules-icon {
  background: linear-gradient(135deg, #ffd740, #ff9100);
}

.ai-icon-action {
  background: linear-gradient(135deg, #18ffff, #448aff);
}

.action-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  text-align: center;
}
